## ──────────────────────────────────────────────────────────────────────────────
## Parsnip AI — Environment Configuration
## ──────────────────────────────────────────────────────────────────────────────
## Docker services communicate via container names on the pi_agent_net bridge.
## Only override URLs when you need to reach services outside Docker (e.g. Ollama
## on a separate host). Defaults in docker-compose.yml are correct for local use.
##
## OLLAMA DEPLOYMENT OPTIONS:
##   A) Ollama on same host (Docker):       http://host.docker.internal:11434
##   B) Ollama on LAN workstation:          http://100.x.y.z:11434  (Tailscale IP)
##   C) Ollama on LAN workstation:          http://192.168.x.x:11434 (LAN IP)
##   D) Ollama Cloud (managed):             OLLAMA_CLOUD_URL=https://ollama.com/v1
##   E) OpenRouter / OpenAI-compatible:      use LLM_PROVIDER=openrouter or openai_compat
## ──────────────────────────────────────────────────────────────────────────────

## Required core settings
POSTGRES_PASSWORD=change-me
WEBUI_SECRET_KEY=replace-with-random-secret

## LLM provider selection: openrouter | openai_compat
LLM_PROVIDER=openrouter
GUARDRAIL_MODE=balanced

## OpenRouter (required when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=sk-or-v1-your-key
DEFAULT_LLM=smart
RESEARCH_LLM=reasoning

## Model alias targets
## Values may be comma-separated fallback chains. DEFAULT_LLM and RESEARCH_LLM
## usually point at aliases such as smart/reasoning rather than raw model IDs.
FAST_MODEL=llama3.1:cloud
SMART_MODEL=kimi-k2.6:cloud
REASONING_MODEL=kimi-k2.6:cloud
GRAPH_MODEL=kimi-k2.6:cloud
CLASSIFIER_MODEL=qwen2.5:3b

## OpenAI-compatible backend (required when LLM_PROVIDER=openai_compat)
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=

## Embeddings / Ollama
## For Ollama inside Docker on same host, use http://host.docker.internal:11434
## For Ollama on a separate workstation (Tailscale), use http://100.x.y.z:11434
## For cloud-only deployments, leave empty and rely on OLLAMA_CLOUD_URL or OpenRouter
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=
OLLAMA_CLOUD_URL=https://ollama.com/v1
EMBED_MODEL=mxbai-embed-large

## Optional GPU model routing
## When set, low/mid-tier tasks route to a local or LAN GPU Ollama instance.
## GPU_LLM_URL should point at the Ollama instance (e.g. http://100.x.y.z:11434)
GPU_LLM_URL=
GPU_LLM_MODEL=
GPU_MID_MODEL=

## Search + integrations
SEARCH_BACKEND=auto
SEARXNG_URL=http://localhost:8080
TAVILY_API_KEY=
BRAVE_API_KEY=
NEWS_API_KEY=
GITHUB_TOKEN=

## Joplin
JOPLIN_ADMIN_EMAIL=admin@pi-agent.local
JOPLIN_ADMIN_PASSWORD=change-me
JOPLIN_BASE_URL=http://localhost:22300

## Frontend (assistant-ui / Next.js)
## NEXT_PUBLIC_AGENT_URL is used by the browser (must be reachable from client)
## AGENT_INTERNAL_URL is used by Next.js SSR (container-to-container, Docker only)
NEXT_PUBLIC_AGENT_URL=http://localhost:8000
# AGENT_INTERNAL_URL=http://pi_agent_backend:8000

## Analysis + storage
ANALYSIS_URL=http://localhost:8095
GCS_BUCKET=
GCS_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
